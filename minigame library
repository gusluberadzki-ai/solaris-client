def asset_path(name: str) -> str:
    return str(SCRIPT_DIR / name)


BACKGROUND_IMG = asset_path("ArcadeBG.gif")
BOUNCE_SOUND = asset_path("bounce.wav")
SNAKE_SCRIPT = asset_path("snake game coding experiments.py")


def play_sound(path: str) -> None:
    """Play a sound in a platform-friendly way."""
    if not Path(path).is_file():
        return
    try:
        if sys.platform == "win32":
            import winsound  # type: ignore

            winsound.PlaySound(path, winsound.SND_FILENAME | winsound.SND_ASYNC)
        elif sys.platform == "darwin":
            subprocess.Popen(["afplay", path], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        else:
            subprocess.Popen(["aplay", path], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass



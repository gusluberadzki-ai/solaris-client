def launch_color_catcher() -> None:
    window = tk.Toplevel(tab)
    window.title("Color Catch")
    window.geometry("360x360")
    window.resizable(False, False)
    target = tk.Button(window, text="Catch me!", font=("Arial", 14, "bold"))
    target.place(x=140, y=140)
    score = tk.IntVar(value=0)
    score_display = tk.Label(window, textvariable=score, font=("Arial", 16))
    score_display.pack(side="bottom", pady=10)

    def move_target():
        x = random.randint(10, 260)
        y = random.randint(10, 260)
        target.place(x=x, y=y)

    def caught():
        score.set(score.get() + 1)
        move_target()

    target.config(command=caught)
    move_target()


def launch_typing_duel() -> None:
    window = tk.Toplevel(tab)
    window.title("Typing Duel")
    window.geometry("360x270")
    window.resizable(False, False)
    heading = tk.Label(window, text="Tap as fast as you can!", font=("Arial", 14))
    heading.pack(pady=8)
    scoreboard = tk.Label(window, text="Player 1: 0   Player 2: 0", font=("Arial", 14))
    scoreboard.pack(pady=4)

    scores = {"p1": 0, "p2": 0}
    goal = 15

    def refresh():
        scoreboard.config(text=f"Player 1: {scores['p1']}   Player 2: {scores['p2']}")
        if scores["p1"] >= goal or scores["p2"] >= goal:
            winner = "Player 1" if scores["p1"] >= goal else "Player 2"
            result.config(text=f"{winner} wins!", fg="green")

    def add_score(player):
        if scores["p1"] >= goal or scores["p2"] >= goal:
            return
        scores[player] += 1
        refresh()

    buttons_frame = tk.Frame(window)
    buttons_frame.pack(pady=8)
    tk.Button(buttons_frame, text="Player 1 Tap", bg="#3CB371", fg="white", font=("Arial", 12, "bold"),
              command=lambda: add_score("p1")).grid(row=0, column=0, padx=12)
    tk.Button(buttons_frame, text="Player 2 Tap", bg="#4169E1", fg="white", font=("Arial", 12, "bold"),
              command=lambda: add_score("p2")).grid(row=0, column=1, padx=12)
    result = tk.Label(window, text="", font=("Arial", 12))
    result.pack(pady=6)


